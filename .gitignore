# ============================================================
# AI Employee Vault - Git Ignore File
# ============================================================

# ============================================================
# 🔴 CRITICAL: ALL DATA FOLDER (contains sessions, credentials)
# ============================================================
data/
**/data/

# ============================================================
# 🔴 CRITICAL: SECRETS & CREDENTIALS
# ============================================================
# Root level
.env
.env.local
.env.*.local
*.secret
credentials.json
token.json
*.pem
*.key
*.crt
*.p12
*.pfx
ngrok.log

# All subdirectories
**/.env
**/.env.local
**/.env.*.local
**/credentials.json
**/token.json
**/*.secret

# ============================================================
# 🔴 CRITICAL: LOGS
# ============================================================
Logs/
*.log
**/*.log

# ============================================================
# 🔴 CRITICAL: DEPLOYMENT & CLOUD CONFIG
# ============================================================
.vercel/
**/.vercel/

# ============================================================
# 🔴 CRITICAL: WHATSAPP & BROWSER SESSIONS
# ============================================================
whatsapp_session/
**/whatsapp_session/
**/instagram_session_default/
**/.wwebjs_cache/
**/puppeteer_profile/

# ============================================================
# 🔴 CRITICAL: BUSINESS DATA
# ============================================================
AI_Employee_Vault/
**/AI_Employee_Vault/

# ============================================================
# 🔴 CRITICAL: DEPLOYMENT & CLOUD CONFIG
# ============================================================
.vercel/
**/.vercel/

# ============================================================
# 🔴 CRITICAL: SCRIPTS WITH HARDCODED TOKENS
# ============================================================
scripts/
whatsapp_session_api/

# ============================================================
# 🔴 CRITICAL: CLOUD & LOCAL AGENTS (contain .env with secrets)
# ============================================================
cloud-api/
local-agent/
servers/

# ============================================================
# 🟡 PYTHON
# ============================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# ============================================================
# 🟡 NODE.JS
# ============================================================
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ============================================================
# 🟡 TESTS
# ============================================================
tests/*.py
!tests/.gitkeep

# ============================================================
# 🟡 IDE & EDITOR
# ============================================================
.vscode/
*.code-workspace
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# 🟡 TEMPORARY FILES
# ============================================================
tmp/
temp/
*.tmp
*.bak
*.old
