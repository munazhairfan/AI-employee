# ============================================================
# AI Employee Vault - Git Ignore File
# ============================================================

# ============================================================
# 🔴 CRITICAL: SECRETS & CREDENTIALS
# ============================================================
# Root level
.env
.env.local
.env.*.local
*.secret
credentials.json
token.json
*.pem
*.key
*.crt
*.p12
*.pfx
ngrok.log

# All subdirectories
**/.env
**/.env.local
**/.env.*.local
**/credentials.json
**/token.json
**/*.secret

# ============================================================
# 🔴 CRITICAL: WHATSAPP & BROWSER SESSIONS
# ============================================================
whatsapp_session/
**/whatsapp_session/
**/instagram_session_default/
**/.wwebjs_cache/
**/puppeteer_profile/
**/playwright_profile/

# ============================================================
# 🔴 CRITICAL: BUSINESS DATA
# ============================================================
AI_Employee_Vault/
Logs/
*.log
**/*.log

# ============================================================
# 🔴 CRITICAL: DATABASE & CONFIG DATA
# ============================================================
data/
**/odoo_config/

# ============================================================
# 🔴 CRITICAL: DEPLOYMENT & CLOUD CONFIG
# ============================================================
.vercel/
**/.vercel/

# ============================================================
# 🔴 CRITICAL: SCRIPTS WITH HARDCODED TOKENS
# ============================================================
scripts/
whatsapp_session_api/

# ============================================================
# 🔴 CRITICAL: CLOUD & LOCAL AGENTS (contain .env with secrets)
# ============================================================
cloud-api/
local-agent/
servers/

# ============================================================
# 🟡 PYTHON
# ============================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# ============================================================
# 🟡 NODE.JS
# ============================================================
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ============================================================
# 🟡 IDE & EDITOR
# ============================================================
.vscode/
*.code-workspace
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# 🟡 TEMPORARY FILES
# ============================================================
tmp/
temp/
*.tmp
*.bak
*.old