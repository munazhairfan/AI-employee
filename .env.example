# ============================================================
# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to Git
# ============================================================

# Email Configuration (Gmail App Password)
# Get app password from: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# Odoo Configuration
ODOO_URL=http://localhost
ODOO_PORT=8069
ODOO_DB=ai_employee_db
ODOO_USER=admin
ODOO_PASS=admin
MCP_PORT=3004

# ============================================================
# API Tokens for MCP Servers (Human-in-the-Loop Execution)
# These are used when drafts are approved for execution
# ============================================================

# ============================================================
# LinkedIn API - TWO OPTIONS:
#
# Option A: Single Account (Simple)
#   - For posting to YOUR LinkedIn only
#   - Manual token generation from dashboard
#   - No OAuth needed
#
# Option B: Multi-User OAuth (Recommended for Production)
#   - For multiple users connecting their LinkedIn
#   - OAuth 2.0 flow
#   - Auto token refresh
#   - Run: node servers/linkedin_oauth_server.js
# ============================================================

# --- Option A: Single Account ---
# Get token from: https://developer.linkedin.com
LINKEDIN_TOKEN=your-linkedin-access-token-here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID

# --- Option B: Multi-User OAuth ---
# Get credentials from: https://www.linkedin.com/developers/apps
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
# Add this redirect URL to your LinkedIn app:
# http://localhost:3006/auth/linkedin/callback

# X (Twitter) API v2
# Get token from: https://developer.twitter.com
X_TWITTER_TOKEN=your-twitter-bearer-token-here

# Facebook Page API
# Get token from: https://developers.facebook.com
FACEBOOK_TOKEN=your-facebook-page-access-token-here
FACEBOOK_PAGE_ID=your-page-id

# Instagram Business API
# Get from: https://developers.facebook.com (same as Facebook)
# Requires Instagram Business or Creator account
INSTAGRAM_TOKEN=your-instagram-access-token-here
INSTAGRAM_USER_ID=your-instagram-business-user-id

# Instagram Graph API (Official - Recommended)
INSTAGRAM_BUSINESS_USER_ID=17841400000000000
INSTAGRAM_ACCESS_TOKEN=your-page-access-token-with-instagram_permissions

# WhatsApp Business API (Choose ONE option)

# Option 1: WhatsApp Web Automation (FREE - Recommended)
# No API keys needed - uses browser automation
USE_WHATSAPP_WEB=true

# Option 2: Twilio (Paid)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Option 3: Meta Official API (Paid after 1000 free conversations)
# Get from: https://developers.facebook.com
WHATSAPP_API_KEY=your-whatsapp-business-api-token-here
META_PHONE_NUMBER_ID=your-phone-number-id-here
